{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "SDKVersion": 2,
  "Author": "HiyokoDev",
  "Name": "Audio Mixer WS",
  "Description": "Controls and monitors Elgato Volume Controller's local audio WebSocket API.",
  "Version": "0.1.0.0",
  "UUID": "fun.hiyoko.audiomixer",
  "Icon": "imgs/plugin-icon",
  "CodePath": "bin/plugin.js",
  "Nodejs": {
    "Version": "24"
  },
  "Software": {
    "MinimumVersion": "7.1"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Actions": [
    {
      "UUID": "fun.hiyoko.audiomixer.master-status",
      "Name": "Master Status",
      "Icon": "imgs/action-status",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/action-status",
          "TitleAlignment": "middle"
        }
      ]
    },
    {
      "UUID": "fun.hiyoko.audiomixer.json-rpc-command",
      "Name": "JSON-RPC Command",
      "Icon": "imgs/action-command",
      "Controllers": ["Keypad"],
      "PropertyInspectorPath": "ui/json-rpc.html",
      "States": [
        {
          "Image": "imgs/action-command",
          "TitleAlignment": "middle"
        }
      ]
    }
  ]
}
